# Backend runtime configuration
# Keep secrets out of source control. Copy to `backend/.env` for local overrides.

FLASK_ENV=development
FLASK_SECRET_KEY=<your-secret-key>
PORT=5000
LOG_LEVEL=info

# Shared infrastructure
DATABASE_URL=postgresql+psycopg://postgres:password@localhost/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_STORAGE_BUCKET=taskhub-assets
REDIS_URL=redis://default:replace-with-password@your-redis-host:6379/0
CORS_ORIGINS=http://localhost:3000

# OAuth
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/oauth/google/callback
GITHUB_CLIENT_ID=<your-github-client-id>
GITHUB_CLIENT_SECRET=<your-github-client-secret>    
GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/oauth/github/callback
ADMIN_EMAILS=admin@example.com
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax

# Email
RESEND_API_KEY=replace-with-resend-key
EMAIL_FROM=TaskHub <admin@example.com>

# AI generation
AI_PROVIDER=huggingface
HF_TOKEN=replace-with-ai-provider-key
HF_PROVIDER=fal
HF_MODEL_ID=black-forest-labs/FLUX.1-Kontext-dev
