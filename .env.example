# TaskHub shared environment contract
# Copy this file to `.env` and replace placeholder values before running any service.

# App URLs
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:5000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# Database and storage
DATABASE_URL=postgresql://postgres:replace-with-password@your-project.supabase.co:5432/postgres?sslmode=require
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_STORAGE_BUCKET=taskhub-assets

# Background jobs
REDIS_URL=redis://default:replace-with-password@your-redis-host:6379/0

# Auth
FLASK_SECRET_KEY=replace-with-a-long-random-secret
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/oauth/google/callback
GITHUB_CLIENT_ID=replace-with-github-client-id
GITHUB_CLIENT_SECRET=replace-with-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/oauth/github/callback
ADMIN_EMAILS=admin@yourdomain.com
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax

# Email
RESEND_API_KEY=replace-with-resend-key
EMAIL_FROM=TaskHub <no-reply@yourdomain.com>

# AI
AI_PROVIDER=huggingface
HF_TOKEN=hf_replace-with-hugging-face-user-access-token
HF_PROVIDER=hf-inference
HF_MODEL_ID=black-forest-labs/FLUX.1-Kontext-dev
AI_IMAGE_SIZE=1024x1024
AI_IMAGE_QUALITY=high

# Runtime
PORT=5000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000
